# CDL chart files — allow same-origin framing and inline scripts (Plotly)
/CDL/charts/*.html
  X-Frame-Options: SAMEORIGIN
  Content-Security-Policy: script-src 'self' 'unsafe-inline'; default-src 'self'

/CDL/charts/Hospitals/*.html
  X-Frame-Options: SAMEORIGIN
  Content-Security-Policy: script-src 'self' 'unsafe-inline'; default-src 'self'

# Never edge-cache backend source files (defensive — they should not be
# in the deployment at all, but this prevents any long-lived caching).
/*.py
  Cache-Control: no-store
